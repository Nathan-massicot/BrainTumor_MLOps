# =============================================================================
# .env.example — copy to .env and fill in your values
# Never commit the .env file (it is gitignored)
# =============================================================================

# --- Weights & Biases ---
# Get your key at https://wandb.ai/authorize
WANDB_API_KEY=
WANDB_PROJECT=brain-tumor-classification
WANDB_ENTITY=

# --- Kaggle ---
# Get from https://www.kaggle.com/settings -> "Create New API Token"
# This downloads a kaggle.json file containing these two fields
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Paths (relative to project root) ---
DATA_DIR=data
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
MODELS_DIR=models

# --- Model / Training ---
MODEL_NAME=resnet18
BATCH_SIZE=32
NUM_EPOCHS=10
LEARNING_RATE=0.001
DEVICE=cuda  # cuda | cpu | mps

# --- DVC remote (configure if using a remote storage backend) ---
# DVC_REMOTE_URL=
